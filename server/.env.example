# OpenRouter API Key (get one free at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Server port
PORT=3001

# Workspace directory for agent file operations
WORKSPACE_DIR=../workspace

# Optional: Set preferred models (defaults shown)
MODEL_SIMPLE=google/gemini-2.5-flash
MODEL_MEDIUM=google/gemini-2.5-pro
MODEL_COMPLEX=anthropic/claude-sonnet-4
